# ========== Token 余额聚合面板 配置 ==========

# 管理员密码（首次启动前请改成你自己的强密码）
ADMIN_PASSWORD=change-me-to-a-strong-password

# 主加密密钥：用于加密存储 API Key
# 留空则首次启动自动生成并写回此文件；一旦生成请勿更换，否则已存的 key 无法解密
MASTER_KEY=

# 面板监听端口
PORT=8000

# SQLite 数据文件名（存放在 ./data 目录）
DB_FILE=tokens.db

# 定时刷新间隔（分钟），默认 15
REFRESH_INTERVAL_MINUTES=15

# 每日报告时间（HH:MM，24小时制，本地时区），默认 09:00
DAILY_REPORT_TIME=09:00

# 会话有效期（小时），默认 720 即 30 天
SESSION_TTL_HOURS=720
